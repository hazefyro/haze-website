{
    "compatibility_date": "2026-04-20",
    "compatibility_flags": ["global_fetch_strictly_public"],
    "name": "haze-website",
    "main": "@astrojs/cloudflare/entrypoints/server",
    "assets": {
        "directory": "./dist",
        "binding": "ASSETS",
    },
    "observability": {
        "enabled": true,
    },
    "routes": [{ "pattern": "haze.fyro.dev", "custom_domain": true }],
    "placement": {
        "mode": "smart",
    },
}
