---
import Section from "./Section.astro";

type Project = {
    name: string;
    desc: string;
    href: string;
};

const { locale } = Astro.props;

let projects;
let title: string;

if (locale === "pl") {
    title = "Projekty";
    projects = [
        {
            name: "DogSmart",
            desc: "super szybka strona portfolio stworzona w Astro",
            href: "https://dogsmart.pl",
        },
        {
            name: "PassCheck",
            desc: "generator haseł działający lokalnie",
            href: "https://passcheck.fyro.dev/",
        },
    ] satisfies Project[];
} else {
    title = "Projects";
    projects = [
        {
            name: "DogSmart",
            desc: "blazing fast portfolio website build with Astro",
            href: "https://dogsmart.pl",
        },
        {
            name: "PassCheck",
            desc: "client-side password generator",
            href: "https://passcheck.fyro.dev/",
        },
    ] satisfies Project[];
}
---

<Section>
    <p class="text-foreground font-bold">{title}</p>
    {
        projects.map(({ name, desc, href }) => (
            <div class="flex flex-col gap-3 sm:gap-2">
                <span class="flex w-full flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                    <a
                        href={href}
                        aria-label={name}
                        class="text-foreground font-medium"
                    >
                        {name}
                    </a>
                    <p class="text-muted">{desc}</p>
                </span>
            </div>
        ))
    }
</Section>
