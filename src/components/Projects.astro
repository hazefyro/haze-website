---
type Project = {
  name: string;
  desc: string;
  href: string;
};

const { locale } = Astro.props;

let projects;

if (locale === "pl") {
  projects = [
    {
      name: "DogSmart",
      desc: "super szybka strona portfolio stworzona w Astro",
      href: "https://dogsmart.pl",
    },
  ] satisfies Project[];
} else {
  projects = [
    {
      name: "DogSmart",
      desc: "blazing fast portfolio website build with Astro",
      href: "https://dogsmart.pl",
    },
  ] satisfies Project[];
}
---

<section class="flex w-full max-w-md flex-col gap-5 text-left lg:max-w-lg">
  <p class="text-foreground font-bold">Projects</p>
  {
    projects.map(({ name, desc, href }) => (
      <div class="flex flex-col gap-3 sm:gap-2">
        <span class="flex w-full flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
          <a href={href} aria-label={name} class="text-foreground font-medium">
            {name}
          </a>
          <p class="text-muted">{desc}</p>
        </span>
      </div>
    ))
  }
</section>
