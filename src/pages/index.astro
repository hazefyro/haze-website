---
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <article
    class="mx-auto flex max-w-4xl flex-col items-center gap-12 px-6 py-24 text-sm lg:gap-14"
  >
    <section
      class="flex w-full max-w-md flex-col items-start gap-5 text-left lg:max-w-xl"
    >
      <h1 class="text-foreground font-medium">hi, I'm haze</h1>
      <p class="text-muted leading-relaxed text-pretty">
        Computer science student.
      </p>
    </section>
    <div
      data-slot="separator"
      role="separator"
      class="h-px, w-full, mx-auto max-w-md bg-black lg:max-w-xl"
    >
    </div>
    <Footer />
  </article>
</Layout>
